<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- GPU-accelerated terminal: requires OpenGL ES 3.x. -->
    <uses-feature
        android:glEsVersion="0x00030002"
        android:required="true" />

    <!--
      Groundwork for a future AVF VM backend (see backend/AvfVmBackend.kt).
      MANAGE_VIRTUAL_MACHINE carries the `development` protection flag, so on a
      personal device it can be granted without platform signing:

          adb shell pm grant dev.nyandroid.terminal \
              android.permission.MANAGE_VIRTUAL_MACHINE

      Booting a *custom* full-Linux VM (own kernel/rootfs) additionally needs
      USE_CUSTOM_VIRTUAL_MACHINE, which is restricted to debuggable/rooted
      builds. The PoC's default LocalPtyBackend needs neither permission.
    -->
    <uses-permission android:name="android.permission.MANAGE_VIRTUAL_MACHINE" />

    <!-- SSH backend connects to the Debian VM on the local avf_tap_fixed bridge. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Foreground service to keep SSH alive in background. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Desktop windowing (Android 16): adaptive, freeform-resizable. -->
    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:resizeableActivity="true"
        android:supportsRtl="false"
        android:theme="@style/Theme.Nyandroid">

        <activity
            android:name=".MainActivity"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|keyboardHidden|keyboard|navigation|density|uiMode"
            android:exported="true"
            android:resizeableActivity="true"
            android:windowSoftInputMode="adjustNothing|stateAlwaysVisible">
            <layout
                android:defaultHeight="600dp"
                android:defaultWidth="900dp"
                android:minHeight="200dp"
                android:minWidth="300dp" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".TerminalService"
            android:foregroundServiceType="specialUse"
            android:exported="false" />

        <activity
            android:name=".SettingsActivity"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|keyboard"
            android:theme="@style/Theme.Nyandroid" />
    </application>

</manifest>
